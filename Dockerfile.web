# Stage 1: Build React SPA
FROM node:20-slim AS frontend-builder
WORKDIR /app/frontend

COPY frontend/package.json ./
RUN npm install

COPY frontend/ ./
RUN npm run build
# Output lands in ../web_server/static (per vite.config.ts outDir)


# Stage 2: Python FastAPI server
FROM python:3.11-slim
WORKDIR /app

# Install dependencies
COPY web_server/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend source
COPY web_server/ ./web_server/
COPY storage/ ./storage/

# Copy pre-built frontend from stage 1
COPY --from=frontend-builder /app/web_server/static ./web_server/static

# Runtime
EXPOSE 8080
CMD ["uvicorn", "web_server.app:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "1"]
