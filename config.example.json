{
  "keywords": [],

  "extraction_rules": [],

  "sources": {
    "github":        {"enabled": true,  "credentials": {"api_token": "${GITHUB_TOKEN}"}},
    "reddit":        {"enabled": false, "credentials": {}},
    "hackernews":    {"enabled": true,  "credentials": {}},
    "stackoverflow": {"enabled": true,  "credentials": {}},
    "producthunt":   {"enabled": false, "credentials": {}},
    "huggingface":   {"enabled": true,  "credentials": {}}
  },

  "filters": {
    "min_score": 0,
    "max_age_days": 90,
    "max_items_per_cycle": 200
  },

  "retention": {
    "ttl_days": 365,
    "irrelevant_ttl_days": 30
  },

  "processor": {
    "relevance_threshold": 0.40,
    "rule_threshold": 0.42,
    "neg_weight": 0.4,
    "neg_min_sim": 0.3,
    "embed_batch_size": 32,
    "summary_batch_size": 5,
    "batch_size": 50,
    "max_tokens_per_batch": 20000,
    "max_body_chars": 1000
  },

  "hybrid_relevance": {
    "enabled": true,
    "domain_high": 0.40,
    "domain_low": 0.28,
    "llm_task_priority": 70,
    "llm_prompt_version": "v6",
    "llm_body_chars": 600,
    "llm_max_tokens": 150,
    "llm_temperature": 0.0,
    "llm_batch_size": 10,
    "domain_anchors": {
      "positive": [
        "AI model training and fine-tuning deep learning",
        "large language model LLM inference and serving",
        "machine learning pipeline MLOps deployment",
        "AI agent framework orchestration tool calling",
        "vector database embeddings semantic search RAG",
        "LLM prompt engineering evaluation benchmark",
        "GPU computing CUDA deep learning acceleration",
        "MCP model context protocol tool integration",
        "retrieval augmented generation knowledge base",
        "open source AI framework library SDK"
      ],
      "negative": [
        "web frontend CSS design HTML template",
        "gaming bot cheat automation game script",
        "political news current events government",
        "cooking recipes food preparation kitchen",
        "sports scores tournament bracket results",
        "e-commerce shopping cart checkout payment",
        "database administration PostgreSQL backup",
        "networking firewall eBPF proxy load balancer",
        "cryptocurrency blockchain mining NFT",
        "mobile app store rejection review"
      ]
    }
  },

  "llm_providers": {
    "claude": {
      "type": "anthropic",
      "api_key": "${ANTHROPIC_API_KEY}",
      "model": "claude-sonnet-4-5"
    }
  },

  "llm_routing": {
    "borderline_relevance": "local",
    "summarize_batch":      "local",
    "resolve_enrich":       "local",
    "query":                "claude"
  },

  "embedder": {
    "model": "BAAI/bge-m3",
    "dimensions": 1024,
    "batch_size": 64,
    "normalize_embeddings": true,
    "device": "cpu"
  },

  "change_report": {
    "enabled": false,
    "interval": "weekly",
    "keywords": [],
    "top_n_new": 10,
    "instructions": "",
    "approved_template": null
  },

  "report": {
    "format": "table",
    "language": "ru",
    "include_links": true,
    "include_evidence": true,
    "top_n": 20,
    "similarity_threshold": 0.5,
    "columns": ["rank", "rank_score", "intensity", "summary", "url"],
    "ranking": {
      "formula": "default",
      "half_life_days": 7,
      "w_engagement": 0.3,
      "w_quality": 0.7
    },
    "export": "markdown"
  }
}
