# Signal Hunter - environment variables
# Copy to .env and fill in your values

# PostgreSQL (docker-compose exposes 5433 on host -> 5432 in container)
DATABASE_URL=postgresql://signal:signal@localhost:5433/signal_hunter

# Qdrant
QDRANT_URL=http://localhost:6333

# GitHub (optional - public rate limit 60 req/hr is enough for testing)
GITHUB_TOKEN=

# Local LLM (required for process/suggest_rules operations)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=devstral

# Anthropic Claude (required for query operation)
ANTHROPIC_API_KEY=
